{
  "name": "hassan-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:report": "vitest run --reporter=html --outputFile test-report/index.html",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-bold": "^2.11.0",
    "@tiptap/extension-document": "^2.11.0",
    "@tiptap/extension-hard-break": "^2.11.0",
    "@tiptap/extension-heading": "^2.11.0",
    "@tiptap/extension-history": "^2.11.0",
    "@tiptap/extension-italic": "^2.11.0",
    "@tiptap/extension-paragraph": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-text": "^2.11.0",
    "@tiptap/extension-typography": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@types/supertest": "^7.2.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
